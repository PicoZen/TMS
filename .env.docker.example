# --- Docker Compose environment template ---
# Copy to .env.docker and fill in real secrets:
#   cp .env.docker.example .env.docker
#
# Used by: postgres, api, celery-worker, celery-beat (see docker-compose.yml
# env_file). Unlike .env (host/local run), hostnames here are Docker service
# names, not localhost, and Postgres is reached on its in-container port 5432
# (not the host-mapped 5433 published in docker-compose.yml).

# Application
APP_NAME=TMS-OC
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO

# Postgres container init vars (consumed directly by the postgres:16-alpine
# image on first start to create the superuser/db - NOT read by the app).
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=tms_oc

# Database (app-level; asyncpg driver). Host = "postgres" service name, port
# 5432 = the container's internal port. Keep user/password/db in sync with
# POSTGRES_USER/POSTGRES_PASSWORD/POSTGRES_DB above.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/tms_oc

# Redis (service name, default port; Celery result backend + rate limiter)
REDIS_URL=redis://redis:6379/0

# RabbitMQ (Celery broker) - service name, default port, default guest/guest creds
CELERY_BROKER_URL=amqp://guest:guest@rabbitmq:5672//

# JWT
JWT_SECRET=your-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# LLM
LLM_PROVIDER=openai
OPENAI_KEY=your-openai-api-key
MISTRAL_KEY=your-mistral-api-key
# "ollama" service name, not localhost - only used when LLM_PROVIDER=ollama
OLLAMA_URL=http://ollama:11434

LLM_MAX_RETRIES=3
LLM_RETRY_BACKOFF_BASE=1.0
LLM_RETRY_BACKOFF_MAX=600

# CORS
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]
