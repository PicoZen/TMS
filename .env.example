# Application
APP_NAME=TMS-OC
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/tms_oc

# Test database (used automatically by `pytest`, see tests/conftest.py -
# not required here, just documenting the default). Same Postgres server as
# above, separate "testdb" database created by
# docker/postgres-init/01-create-testdb.sql. Override by exporting
# DATABASE_URL before running pytest if you want to point tests elsewhere.
# TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/testdb

# Redis (Celery result backend + rate limiter store)
REDIS_URL=redis://localhost:6379/0

# RabbitMQ (Celery broker)
CELERY_BROKER_URL=amqp://guest:guest@localhost:5672//

# JWT
JWT_SECRET=7VgGQ26Fij506Pe9sf7e7HvxEJg1slSRBoJN2v1oT6j
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# LLM
LLM_PROVIDER=openai
OPENAI_KEY=your-openai-api-key
MISTRAL_KEY=your-mistral-api-key
OLLAMA_URL=http://localhost:11434

# LLM call retry (Celery task-level retry with exponential backoff - see
# src/tasks/classification_tasks.py). LLM_MAX_RETRIES=3 means up to 4 total
# attempts. Delay per retry is llm_retry_backoff_base * 2^retry_number,
# capped at LLM_RETRY_BACKOFF_MAX seconds.
LLM_MAX_RETRIES=3
LLM_RETRY_BACKOFF_BASE=1.0
LLM_RETRY_BACKOFF_MAX=600

# CORS
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]